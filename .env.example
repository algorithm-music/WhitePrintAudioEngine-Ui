# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ──────────────────────────────────────────
# WhitePrintAudioEngine Backend (concertmaster)
# ──────────────────────────────────────────

# CONCERTMASTER_URL: The base URL of the concertmaster service.
# In development: http://localhost:8000
# In production: Cloud Run service URL (e.g. https://concertmaster-xxxxx-an.a.run.app)
CONCERTMASTER_URL="http://localhost:8000"

# CONCERTMASTER_API_KEY: The X-Api-Key for authenticating with concertmaster.
# Server-side only — NEVER prefix with NEXT_PUBLIC_.
CONCERTMASTER_API_KEY="your-api-key-here"

# ──────────────────────────────────────────
# GCS File Upload
# ──────────────────────────────────────────

# GCS_SOURCE_BUCKET: The GCS bucket where uploaded audio files are stored.
# The Cloud Run service account must have Storage Object Admin role on this bucket.
GCS_SOURCE_BUCKET="aidriven-mastering-fyqu-source-bucket"

# ──────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────

# NEXT_PUBLIC_SUPABASE_URL: Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: Public anon key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Server-side only — used for webhook handlers
# NEVER prefix with NEXT_PUBLIC_. Found in Supabase Dashboard → Settings → API
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ──────────────────────────────────────────
# NOWPayments
# ──────────────────────────────────────────

# NOWPAYMENTS_API_KEY: Server-side only — for creating invoices
NOWPAYMENTS_API_KEY="your-nowpayments-api-key"

# NOWPAYMENTS_IPN_SECRET: Server-side only — for webhook signature verification
NOWPAYMENTS_IPN_SECRET="your-ipn-secret"
